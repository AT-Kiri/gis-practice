# LLM API 配置（硅基流动 SiliconFlow）
# 注册地址：https://siliconflow.cn/  注册后在「API 密钥」页面创建 Key
# 注意：变量名虽为 DEEPSEEK_API_KEY，实际填入的是硅基流动的 API Key
DEEPSEEK_API_KEY=sk-your-siliconflow-api-key-here
DEEPSEEK_BASE_URL=https://api.siliconflow.cn/v1
DEEPSEEK_MODEL=deepseek-ai/DeepSeek-V3.2

# iServer 配置
ISERVER_URL=http://localhost:8090

# 后端配置
HOST=0.0.0.0
PORT=8001

# RAG 配置（硅基流动 SiliconFlow - BAAI/bge-m3，与 LLM 共用 API Key）
# EMBEDDING_API_KEY 留空则回退到 DEEPSEEK_API_KEY（见 llm_service.py）
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=BAAI/bge-m3
